# ─────────────────────────────────────────────────────────────────────────────
# Project Atlas — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# SQLAlchemy-compatible PostgreSQL URL. Works with any provider.
#
# Supabase (direct connection — recommended for development):
#   DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# Local PostgreSQL:
#   DATABASE_URL=postgresql://atlas:atlas_secret@localhost:5432/atlas
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# ─── Application ─────────────────────────────────────────────────────────────
# Env: development | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ─── Future: News API (Phase 2) ───────────────────────────────────────────────
# NEWS_API_KEY=your_newsapi_key_here
